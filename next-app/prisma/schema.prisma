datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  passwordHash String        @map("password_hash")
  role         String        // "admin" | "procurement_officer" | "manager" | "vendor"
  createdAt    DateTime      @default(now()) @map("created_at")
  rfqs         Rfq[]
  requestedApprovals Approval[] @relation("RequestedBy")
  approvals    Approval[]    @relation("Approver")
  activityLogs ActivityLog[]

  @@map("users")
}

model Vendor {
  id           String    @id @default(uuid())
  name         String
  category     String
  gstNumber    String    @map("gst_number")
  contactName  String    @map("contact_name")
  contactEmail String    @map("contact_email")
  contactPhone String?   @map("contact_phone")
  address      String?
  status       String    @default("active")  // "active" | "inactive" | "blacklisted"
  rating       Float     @default(0.0)
  createdAt    DateTime  @default(now()) @map("created_at")

  rfqs         Rfq[]
  quotations   Quotation[]
  purchaseOrders PurchaseOrder[]

  @@map("vendors")
}

model Rfq {
  id          String      @id @default(uuid())
  title       String
  description String
  status      String      @default("draft") // "draft" | "open" | "closed" | "cancelled"
  deadline    DateTime
  createdBy   User        @relation(fields: [createdById], references: [id])
  createdById String      @map("created_by")
  createdAt   DateTime    @default(now()) @map("created_at")

  items       RfqItem[]
  vendors     Vendor[]
  quotations  Quotation[]

  @@map("rfqs")
}

model RfqItem {
  id          String  @id @default(uuid())
  rfq         Rfq     @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  rfqId       String  @map("rfq_id")
  productName String  @map("product_name")
  quantity    Int
  unit        String  @default("pcs")

  @@map("rfq_items")
}

model Quotation {
  id           String     @id @default(uuid())
  rfq          Rfq        @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  rfqId        String     @map("rfq_id")
  vendor       Vendor     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  vendorId     String     @map("vendor_id")
  unitPrice    Float      @map("unit_price")
  totalPrice   Float      @map("total_price")
  deliveryDays Int        @map("delivery_days")
  notes        String?
  status       String     @default("submitted") // "submitted" | "shortlisted" | "rejected" | "accepted"
  submittedAt  DateTime   @default(now()) @map("submitted_at")

  approvals    Approval[]
  purchaseOrders PurchaseOrder[]

  @@map("quotations")
}

model Approval {
  id            String    @id @default(uuid())
  quotation     Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  quotationId   String    @map("quotation_id")
  requestedBy   User      @relation("RequestedBy", fields: [requestedById], references: [id])
  requestedById String    @map("requested_by")
  approver      User?     @relation("Approver", fields: [approverId], references: [id])
  approverId    String?   @map("approver_id")
  status        String    @default("pending") // "pending" | "approved" | "rejected"
  remarks       String?
  actionedAt    DateTime? @map("actioned_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  purchaseOrder PurchaseOrder?

  @@map("approvals")
}

model PurchaseOrder {
  id           String    @id @default(uuid())
  poNumber     String    @unique @map("po_number")
  quotation    Quotation @relation(fields: [quotationId], references: [id])
  quotationId  String    @map("quotation_id")
  vendor       Vendor    @relation(fields: [vendorId], references: [id])
  vendorId     String    @map("vendor_id")
  approval     Approval  @relation(fields: [approvalId], references: [id])
  approvalId   String    @unique @map("approval_id")
  subtotal     Float
  taxPercent   Float     @default(18.0) @map("tax_percent")
  taxAmount    Float     @map("tax_amount")
  totalAmount  Float     @map("total_amount")
  status       String    @default("issued") // "issued" | "acknowledged" | "delivered" | "cancelled"
  issuedAt     DateTime  @default(now()) @map("issued_at")

  invoices     Invoice[]

  @@map("purchase_orders")
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique @map("invoice_number")
  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id])
  poId          String        @map("po_id")
  issuedDate    DateTime      @default(now()) @map("issued_date")
  dueDate       DateTime      @map("due_date")
  status        String        @default("draft") // "draft" | "sent" | "paid" | "overdue"
  pdfUrl        String?       @map("pdf_url")
  emailedAt     DateTime?     @map("emailed_at")
  createdAt     DateTime      @default(now()) @map("created_at")

  @@map("invoices")
}

model ActivityLog {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String   @map("user_id")
  entityType String   @map("entity_type") // "rfq" | "quotation" | "approval" | "po" | "invoice" | "vendor"
  entityId   String   @map("entity_id")
  action     String   // "created" | "approved" | "rejected" | "emailed" | "shortlisted" | etc.
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("activity_logs")
}
